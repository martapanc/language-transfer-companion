---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Topic lists and downloadable practice flashcards for the Language Transfer language courses. An unofficial community companion.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23c8452f'/%3E%3Ctext x='50' y='72' font-size='62' text-anchor='middle' fill='white' font-family='sans-serif' font-weight='bold'%3ELT%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">LT</span>
          <span>Language Transfer <span style="color:var(--text-muted);font-weight:500">Companion</span></span>
        </a>
        <nav>
          <a href="/#languages">Languages</a>
          <a href="/#about">About</a>
          <a href="https://www.languagetransfer.org" target="_blank" rel="noopener">Official site ↗</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>
          An unofficial, community-made companion. Built with love for the
          <a href="https://www.languagetransfer.org" target="_blank" rel="noopener">Language Transfer</a> method.
        </span>
        <span>Not affiliated with or endorsed by Language Transfer.</span>
      </div>
    </footer>
  </body>
</html>
