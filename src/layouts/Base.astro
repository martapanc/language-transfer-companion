---
import '../styles/global.css';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Topic lists and downloadable practice flashcards for the Language Transfer language courses. An unofficial community companion.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23141414'/%3E%3Ctext x='50' y='72' font-size='62' text-anchor='middle' fill='white' font-family='sans-serif' font-weight='bold'%3ELT%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">LT</span>
          <span>Language Transfer <span class="text-muted font-medium">Companion</span></span>
        </a>
        <nav>
          <a href="/#languages">Languages</a>
          <a href="/#about">About</a>
          <a class="inline-flex items-center gap-1" href="https://www.languagetransfer.org" target="_blank" rel="noopener">Official site <Icon name="arrow-up-right" size={14} /></a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer mb-10 sm:mb-16">
      <div class="wrap">
        An unofficial, community-made companion. Built with love for the
        <a href="https://www.languagetransfer.org" target="_blank" rel="noopener" class="ms-1">Language Transfer</a> method.
        <br/>
        Not affiliated with or endorsed by Language Transfer.
      </div>
    </footer>

    <button id="back-to-top" class="back-to-top" type="button" aria-label="Back to top"><Icon name="arrow-up" size={18} /></button>

    <script>
      const backToTop = document.getElementById('back-to-top');
      if (backToTop) {
        const toggle = () =>
          backToTop.classList.toggle('is-visible', window.scrollY > 400);
        toggle();
        window.addEventListener('scroll', toggle, { passive: true });
        backToTop.addEventListener('click', () =>
          window.scrollTo({ top: 0, behavior: 'smooth' }),
        );
      }
    </script>
  </body>
</html>
