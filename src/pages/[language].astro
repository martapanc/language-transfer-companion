---
import Base from '../layouts/Base.astro';
import PartSection from '../components/PartSection.astro';
import { getAvailableSlugs, getCourse } from '../lib/content';
import type { Course } from '../lib/types';

export function getStaticPaths() {
  return getAvailableSlugs().map((slug) => ({
    params: { language: slug },
    props: { course: getCourse(slug) },
  }));
}

interface Props {
  course: Course;
}

const { course } = Astro.props;
const decksAvailable = course.parts.filter((p) => p.flashcard).length;
const decksZipHref = `/downloads/${course.slug}/${course.slug}-flashcards.zip`;
---

<Base
  title={`${course.name} — Language Transfer Companion`}
  description={`Topic list for all ${course.trackCount} tracks of Language Transfer ${course.courseName}, plus ${course.totalCards} downloadable practice flashcards.`}
>
  <section class="hero wrap">
    <a class="backlink" href="/#languages">← All languages</a>
    <span class="eyebrow">{course.flag} {course.courseName}</span>
    <h1>{course.name} — topics & flashcards</h1>
    <p class="lede">{course.tagline}</p>

    <div class="stats">
      <div class="stat">
        <div class="num">{course.trackCount}</div>
        <div class="label">tracks</div>
      </div>
      <div class="stat">
        <div class="num">{course.parts.length}</div>
        <div class="label">thematic parts</div>
      </div>
      <div class="stat">
        <div class="num">{course.totalCards.toLocaleString()}</div>
        <div class="label">flashcards</div>
      </div>
      <div class="stat">
        <div class="num">{decksAvailable}</div>
        <div class="label">downloadable decks</div>
      </div>
    </div>

    <div class="hero-actions">
      {
        decksAvailable > 0 && (
          <a class="btn btn-primary" href={decksZipHref} download>
            ⬇︎ Download all {decksAvailable} decks (.zip)
          </a>
        )
      }
      {
        course.summariesDownload && (
          <a class="btn btn-ghost" href={course.summariesDownload} download>
            ⬇︎ Topic summaries (Markdown)
          </a>
        )
      }
    </div>
  </section>

  <section class="section wrap">
    <div class="search-bar" id="search-bar">
      <span class="search-icon" aria-hidden="true">🔎</span>
      <input
        type="search"
        id="track-search"
        autocomplete="off"
        aria-label={`Search ${course.name} track topics`}
        placeholder="Search topics — e.g. numbers, reflexive, future…"
      />
      <button type="button" class="search-clear" id="search-clear" aria-label="Clear search">×</button>
    </div>
    <p class="search-count" id="search-count" hidden></p>

    <div id="toc-block">
      <h2 class="section-title">Jump to a part</h2>
      <nav class="toc" aria-label="Course parts">
        {
          course.parts.map((part) => (
            <a href={`#part-${part.id}`}>
              <span class="toc-part">
                {part.id}. {part.title}
              </span>
              <span class="toc-range">
                {part.trackStart}–{part.trackEnd}
              </span>
            </a>
          ))
        }
      </nav>

      {course.notes && <p class="callout" style="margin-top:1.5rem">{course.notes}</p>}
    </div>

    <p class="no-results" id="no-results" hidden>
      <strong>No tracks match your search.</strong> Try a different word.
    </p>

    <div id="parts">
      {course.parts.map((part) => <PartSection part={part} />)}
    </div>
  </section>

  <script>
    const input = document.getElementById('track-search') as HTMLInputElement | null;
    if (input) {
      const bar = document.getElementById('search-bar');
      const clearBtn = document.getElementById('search-clear');
      const countEl = document.getElementById('search-count');
      const noResults = document.getElementById('no-results');
      const tocBlock = document.getElementById('toc-block');
      const tracks = Array.from(
        document.querySelectorAll<HTMLElement>('#parts .track'),
      ).map((el) => ({ el, text: (el.textContent || '').toLowerCase() }));
      const parts = Array.from(document.querySelectorAll<HTMLElement>('#parts .part'));
      const total = tracks.length;

      const apply = (raw: string) => {
        const query = raw.trim().toLowerCase();
        const active = query.length > 0;
        bar?.classList.toggle('has-query', active);
        let visible = 0;
        for (const t of tracks) {
          const match = !active || t.text.includes(query);
          t.el.hidden = !match;
          if (match) visible++;
        }
        for (const p of parts) {
          p.hidden = active && !p.querySelector('.track:not([hidden])');
        }
        if (tocBlock) tocBlock.hidden = active;
        if (countEl) {
          countEl.hidden = !active;
          countEl.textContent = active
            ? `${visible} of ${total} track${total === 1 ? '' : 's'} match “${raw.trim()}”`
            : '';
        }
        if (noResults) noResults.hidden = !(active && visible === 0);
      };

      input.addEventListener('input', () => apply(input.value));
      clearBtn?.addEventListener('click', () => {
        input.value = '';
        apply('');
        input.focus();
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          input.value = '';
          apply('');
        }
      });
    }
  </script>
</Base>
