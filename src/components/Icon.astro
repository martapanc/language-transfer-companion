---
/**
 * Small monochrome UI icons as inline SVG, replacing the pictographic emoji
 * (search, download, deck) and symbol glyphs (arrows, close) the site used to
 * rely on. Drawn in a Lucide-style 24×24 stroke grid so they stay crisp and
 * inherit `currentColor`, keeping them on-theme in both light and dark mode.
 */
interface Props {
  name: keyof typeof PATHS;
  /** Rendered width/height in px. */
  size?: number;
  class?: string;
}

const PATHS = {
  search: '<circle cx="11" cy="11" r="7"/><line x1="20" y1="20" x2="16.65" y2="16.65"/>',
  download: '<path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M4 21h16"/>',
  deck: '<rect x="3" y="7" width="13" height="14" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-2"/>',
  'arrow-left': '<line x1="20" y1="12" x2="5" y2="12"/><path d="m12 19-7-7 7-7"/>',
  'arrow-up': '<line x1="12" y1="20" x2="12" y2="5"/><path d="m5 12 7-7 7 7"/>',
  'arrow-up-right': '<path d="M8 16 16 8"/><path d="M9 8h7v7"/>',
  close: '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
} as const;

const { name, size = 20, class: className = '' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['icon', className]}
  aria-hidden="true"
  set:html={PATHS[name]}
/>
