---
import type { Part } from '../lib/types';
import { renderSummary } from '../lib/inline';

interface Props {
  part: Part;
}

const { part } = Astro.props;
const anchor = `part-${part.id}`;
---

<section class="part" id={anchor}>
  <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-3 pb-[0.9rem] border-b-2 border-border">
    <div>
      <div class="text-[0.82rem] font-semibold uppercase tracking-[0.06em] text-accent">Part {part.id}</div>
      <h2 class="text-[1.55rem] font-extrabold">{part.title}</h2>
    </div>
    <div class="text-muted text-[0.9rem]">Tracks {part.trackStart}–{part.trackEnd}</div>
  </div>

  {
    part.flashcard && (
      <div class="download">
        <span class="dl-icon" aria-hidden="true">🃏</span>
        <div class="dl-text">
          <strong>Practice flashcards</strong>
          <span>{part.flashcard.cardCount} cards · CSV for Anki, Quizlet, or any SRS</span>
        </div>
        <a class="btn btn-primary" href={part.flashcard.href} download>
          Download deck
        </a>
      </div>
    )
  }

  <ol class="mt-5 grid gap-[0.6rem]">
    {
      part.tracks.map((track) => (
        <li class="track" id={`track-${track.number}`}>
          <span class="track-num">{track.number}</span>
          <span class="track-title">
            {track.title}
            <a
              class="track-anchor"
              href={`#track-${track.number}`}
              aria-label={`Permalink to track ${track.number}`}
            >
              #
            </a>
          </span>
          <div class="track-summary" set:html={renderSummary(track.summary)} />
        </li>
      ))
    }
  </ol>
</section>
